# --- svelte-adapter-bun runtime ---
# What the production server listens on.
HOST=0.0.0.0
PORT=3000

# Required in production: the externally reachable URL of this deployment.
# SvelteKit uses this for same-origin checks on form submissions — if it's
# wrong, every form action (login, settings, feeds) will fail with a 403.
# Should match BETTER_AUTH_URL below.
ORIGIN=http://localhost:3000

# Only relevant if this sits behind a reverse proxy (Traefik, Caddy, nginx).
# XFF_DEPTH is how many trusted proxies are in front of the app (1 for a
# single Traefik hop, which is the common homelab setup).
XFF_DEPTH=1
ADDRESS_HEADER=X-Forwarded-For
PROTOCOL_HEADER=X-Forwarded-Proto
HOST_HEADER=X-Forwarded-Host

# --- application ---

# Path to the SQLite database file. The directory is created automatically.
DATABASE_PATH=./data/quiet-feed.db

# Better Auth requires a stable secret for signing sessions/tokens.
# Generate one with: bunx @better-auth/cli secret
BETTER_AUTH_SECRET=change-me

# The externally reachable URL of this deployment. Should match ORIGIN above.
BETTER_AUTH_URL=http://localhost:3000

# Shared secret required in the Authorization header of /api/cron/compile.
# Generate something long and random: openssl rand -hex 32
CRON_SECRET=change-me

# Set to "true" to run an in-process scheduler (every 10 min) that checks
# whether each user's edition time has passed and compiles if so. Turn this
# OFF if an external cron / systemd timer is already hitting
# /api/cron/compile, to avoid double-running the job.
ENABLE_INTERNAL_SCHEDULER=true

# Used to set the "Secure" flag on session cookies. Set to "true" once the
# app is served over HTTPS (recommended for anything but local dev).
SECURE_COOKIES=false
